# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Bartender Dashboard Security
# Set this to a random secret string for bartender dashboard access
BARTENDER_DASH_KEY=your-secret-key-here

# Monthly Report Email (Brevo SMTP — https://brevo.com)
BREVO_SMTP_PASSWORD=your-brevo-smtp-password-here

# Vercel Cron Secret (auto-set by Vercel in production — set manually for local testing)
CRON_SECRET=your-cron-secret-here
